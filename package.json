{
  "name": "satisfactory-map-connector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "node --watch server/index.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/index.js",
    "cron": "node server/cron.js",
    "lint": "node scripts/validate-config.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "node-cron": "^3.0.3",
    "ssh2-sftp-client": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "vite": "^5.4.11"
  }
}
